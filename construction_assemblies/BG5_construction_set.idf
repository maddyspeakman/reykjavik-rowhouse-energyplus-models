! BG5 WINDOW MATERIAL DEFINITIONS
! --------------------------------------------------------------------------------------------------

WindowMaterial:SimpleGlazingSystem,
  BG5 - Glazing,                          !- Name
  2,                                      !- U-Factor {W/m2-K}
  0.58,                                   !- Solar Heat Gain Coefficient
  0.57;                                   !- Visible Transmittance

! BG5 CONSTRUCTION ASSEMBLIES
! --------------------------------------------------------------------------------------------------

! FLOOR-ON-FILL / GROUND FLOORS

Construction,
  BG5 - Floor on Fill,                    !- Name
  BG5 - Floor on Fill Insulation,         !- Layer 1
  BG5 - Concrete Floor Slab,              !- Layer 2
  BG5 - Floor Finish (15mm wood);         !- Layer 3

! INTERIOR FLOORS

Construction,
  BG5 - Interior Floor,                      !- Name
  BG5 - Int Wall Finish (13mm gypsum board), !- Layer 1
  BG5 - Concrete Floor Slab,                 !- Layer 2
  BG5 - Floor Finish (15mm wood);            !- Layer 3

! EXTERIOR WALLS

Construction,
  BG5 - Ext Wall (ext insulation),           !- Name
  BG5 - Ext Wall Façade (cement plaster),    !- Layer 1
  BG5 - Ext Wall Insulation,                 !- Layer 2
  BG5 - Ext Wall Concrete Block,             !- Layer 3
  BG5 - Int Wall Finish (13mm gypsum board); !- Layer 4

Construction,
  BG5 - Ext Wall (int insulation),           !- Name
  BG5 - Ext Wall Façade (cement plaster),    !- Layer 1
  BG5 - Ext Wall Concrete Block,             !- Layer 2
  BG5 - Ext Wall Insulation,                 !- Layer 3
  BG5 - Int Wall Finish (13mm gypsum board); !- Layer 4

! PARTY WALLS

Construction,
  BG5 - Party Wall,                          !- Name
  BG5 - Party Wall Concrete Block,           !- Layer 1
  BG5 - Int Wall Finish (13mm gypsum board); !- Layer 2

! ROOF / CEILING ASSEMBLIES

Construction,
  BG5 - RoofCeiling (concrete),              !- Name
  BG5 - Roof Metal Cladding,                 !- Layer 1
  BG5 - Roof Insulation (concrete),          !- Layer 2
  BG5 - Ext Wall Concrete Block,             !- Layer 3
  BG5 - Int Wall Finish (13mm gypsum board); !- Layer 4

Construction,
  BG5 - RoofCeiling (timber & metal),        !- Name
  BG5 - Roof Metal Cladding,                 !- Layer 1
  BG5 - Roof Insulation (timber & metal),    !- Layer 2
  BG5 - Roof Plywood Sheathing,              !- Layer 3
  BG5 - Int Wall Finish (13mm gypsum board); !- Layer 4

! EXTERIOR OPAQUE DOORS

Construction,
  BG5 - Ext Door (opaque),                !- Name
  BG5 - Ext Door (pine);                  !- Layer 1

! WINDOWS AND GLASS DOORS

Construction,
  BG5 - Window/GlassDoor,                 !- Name
  BG5 - Glazing;                          !- Layer 1


