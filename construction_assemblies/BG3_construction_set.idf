! BG3 WINDOW MATERIAL DEFINITIONS
! --------------------------------------------------------------------------------------------------

WindowMaterial:SimpleGlazingSystem,
  BG3 - Glazing,                          !- Name
  2.5,                                    !- U-Factor {W/m2-K}
  0.58,                                   !- Solar Heat Gain Coefficient
  0.57;                                   !- Visible Transmittance

! BG3 CONSTRUCTION ASSEMBLIES
! --------------------------------------------------------------------------------------------------

! FLOOR-ON-FILL / GROUND FLOORS

Construction,
  BG3 - Floor on Fill,                    !- Name
  BG3 - Floor on Fill Insulation,         !- Layer 1
  BG3 - Concrete Floor Slab,              !- Layer 2
  BG3 - Floor Finish (15mm wood);         !- Layer 3

! GROUND-CONTACT WALLS

Construction,
  BG3 - Ground Contact Wall,              !- Name
  BG3 - Ext Wall Concrete Block,          !- Layer 1
  BG3 - Ground Contact Wall Insulation,   !- Layer 2
  BG3 - Int Wall Finish (13mm gypsum board); !- Layer 3

! INTERIOR FLOORS

Construction,
  BG3 - Interior Floor,                   !- Name
  BG3 - Floor Finish (15mm wood),         !- Layer 1
  BG3 - Concrete Floor Slab,              !- Layer 2
  BG3 - Int Wall Finish (13mm gypsum board); !- Layer 3

! EXTERIOR WALLS

Construction,
  BG3 - Ext Wall,                         !- Name
  BG3 - Ext Wall Façade (Cement Plaster), !- Layer 1
  BG3 - Ext Wall Concrete Block,          !- Layer 2
  BG3 - Ext Wall Insulation,              !- Layer 3
  BG3 - Int Wall Finish (13mm gypsum board); !- Layer 4

! PARTY WALLS

Construction,
  BG3 - Party Wall,                       !- Name
  BG3 - Party Wall Concrete Block,        !- Layer 1
  BG3 - Int Wall Finish (13mm gypsum board); !- Layer 2

! ROOF / CEILING ASSEMBLIES

Construction,
  BG3 - RoofCeiling,                      !- Name
  BG3 - Roof Metal Cladding,              !- Layer 1
  BG3 - Roof Insulation,                  !- Layer 2
  BG3 - Ext Wall Concrete Block,          !- Layer 3
  BG3 - Int Wall Finish (13mm gypsum board); !- Layer 4

! EXTERIOR OPAQUE DOORS

Construction,
  BG3 - Ext Door,                         !- Name
  BG3 - Ext Door (Pine Wood);             !- Layer 1

! WINDOWS AND GLASS DOORS

Construction,
  BG3 - Window/GlassDoor,                 !- Name
  BG3 - Glazing;                          !- Layer 1
