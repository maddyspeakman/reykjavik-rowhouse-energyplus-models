! BG1 WINDOW MATERIAL DEFINITION
! --------------------------------------------------------------------------------------------------

WindowMaterial:SimpleGlazingSystem,
  BG1 - Glazing,                          !- Name
  2.5,                                    !- U-Factor {W/m2-K}
  0.58,                                   !- Solar Heat Gain Coefficient
  0.57;                                   !- Visible Transmittance

! BG1 CONSTRUCTION ASSEMBLIES
! --------------------------------------------------------------------------------------------------

! FLOOR-ON-FILL / GROUND FLOORS

Construction,
  BG1 - Floor on Fill,                    !- Name
  BG1 - Floor on Fill Insulation,         !- Layer 1
  BG1 - Concrete Floor Slab,              !- Layer 2
  BG1 - Floor Finish (15mm wood);         !- Layer 3

! INTERIOR FLOORS

Construction,
  BG1 - Interior Floor,                   !- Name
  BG1 - Concrete Floor Slab,              !- Layer 1
  BG1 - Floor Finish (15mm wood);         !- Layer 2

! EXTERIOR WALLS

Construction,
  BG1 - Ext Wall (Concrete),              !- Name
  BG1 - Ext Wall Façade (Cement Plaster), !- Layer 1
  BG1 - Ext Wall Concrete Block,          !- Layer 2
  BG1 - Ext Wall Insulation (Heavyweight), !- Layer 3
  BG1 - Int Wall Finish (13mm gypsum board); !- Layer 4

Construction,
  BG1 - Ext Wall (Timber),                !- Name
  BG1 - Roof Metal Cladding,              !- Layer 1
  BG1 - Ext Wall Plywood Sheathing,       !- Layer 2
  BG1 - Ext Wall Insulation (Lightweight), !- Layer 3
  BG1 - Int Wall Finish (13mm gypsum board); !- Layer 4

! PARTY WALLS

Construction,
  BG1 - Party Wall,                       !- Name
  BG1 - Party Wall Concrete Block,        !- Layer 1
  BG1 - Int Wall Finish (13mm gypsum board); !- Layer 2

! ROOF / CEILING ASSEMBLIES

Construction,
  BG1 - RoofCeiling (Metal),              !- Name
  BG1 - Roof Metal Cladding,              !- Layer 1
  BG1 - Ext Wall Plywood Sheathing,       !- Layer 2
  BG1 - Roof Insulation (timber),         !- Layer 3
  BG1 - Int Wall Finish (13mm gypsum board); !- Layer 4

Construction,
  BG1 - RoofCeiling (Non-metal),          !- Name
  BG1 - Ext Wall Concrete Block,          !- Layer 1
  BG1 - Roof Insulation (concrete),       !- Layer 2
  BG1 - Int Wall Finish (13mm gypsum board); !- Layer 3

! EXTERIOR OPAQUE DOORS

Construction,
  BG1 - Ext Door,                         !- Name
  BG1 - Ext Door (wood);                  !- Layer 1

! WINDOWS AND GLASS DOORS

Construction,
  BG1 - Window/GlassDoor,                 !- Name
  BG1 - Glazing;                          !- Layer 1
