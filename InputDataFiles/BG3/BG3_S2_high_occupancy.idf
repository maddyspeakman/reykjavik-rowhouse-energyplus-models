!-----------------------------------------------------------------------------
! Shading due to balcony and roof overhangs
!   All overhangs (excluding Basement West Terrace & Floor 1 West Terrace)
!   slope downward at 20º and extend across entire façades
!   ∆y = L_overhang * cos(20º)
!   ∆z = L_overhang * sin(20º)
!-----------------------------------------------------------------------------

! West Terrace Wall - Basement (L_overhang =  m, balcony: θ = 0)
Shading:Building:Detailed,
  Overhang_WestTerraceWall0,     !- Name
  ,                              !- Transmittance Schedule Name
  4,                             !- Number of Vertices
  0.0, 9.9, 2.4,                 !- Vertex 1 (inner edge)
  3.0, 9.9, 2.4,                 !- Vertex 2 (inner edge)
  3.0, 10.6, 2.4,                !- Vertex 3 (outer edge)
  0.0, 10.6, 2.4;                !- Vertex 4 (outer edge)

! East Terrace Wall - Floor 1 (L_overhang = 2.4 m)
Shading:Building:Detailed,
  Overhang_EastTerraceWall1,     !- Name
  ,                              !- Transmittance Schedule Name
  4,                             !- Number of Vertices
  3.0, 1.3, 5.1,                 !- Vertex 1 (inner edge)
  0.0, 1.3, 5.1,                 !- Vertex 2 (inner edge)
  0.0, -0.9552622, 4.2791518,    !- Vertex 3 (outer edge)
  3.0, -0.9552622, 4.2791518;    !- Vertex 4 (outer edge)

! West Terrace Wall - Floor 1 (L_overhang =  m, balcony: θ = 0)
Shading:Building:Detailed,
  Overhang_WestTerraceWall1,     !- Name
  ,                              !- Transmittance Schedule Name
  4,                             !- Number of Vertices
  0.0, 9.9, 5.1,                 !- Vertex 1 (inner edge)
  3.0, 9.9, 5.1,                 !- Vertex 2 (inner edge)
  3.0, 10.6, 5.1,                !- Vertex 3 (outer edge)
  0.0, 10.6, 5.1;                !- Vertex 4 (outer edge)

! East Wall - Floor 2 (L_overhang = 1.0 m)
Shading:Building:Detailed,
  Overhang_EastWall2,            !- Name
  ,                              !- Transmittance Schedule Name (blank = opaque)
  4,                             !- Number of Vertices
  8.0, 0.0, 7.8,                 !- Vertex 1 (inner edge)
  3.0, 0.0, 7.8,                 !- Vertex 2 (inner edge)
  3.0, -0.9396926, 7.4579799,    !- Vertex 3 (outer edge)
  8.0, -0.9396926, 7.4579799;    !- Vertex 4 (outer edge)

! East Terrace Wall - Floor 2 (L_overhang = 0.8 m)
Shading:Building:Detailed,
  Overhang_EastTerraceWall2,     !- Name
  ,                              !- Transmittance Schedule Name
  4,                             !- Number of Vertices
  3.0, 1.3, 7.8,                 !- Vertex 1 (inner edge)
  0.0, 1.3, 7.8,                 !- Vertex 2 (inner edge)
  0.0, 0.5482459, 7.5263839,     !- Vertex 3 (outer edge)
  3.0, 0.5482459, 7.5263839;     !- Vertex 4 (outer edge)

! West Wall - Floor 2 (L_overhang = 1.0 m)
Shading:Building:Detailed,
  Overhang_WestWall2,            !- Name
