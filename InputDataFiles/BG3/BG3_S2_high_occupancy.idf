! ====================================================================================================
! INFILTRATION:
! Based on airtightness measurements for houses built in 1980s (Marteinsson, 2012): q_50 = 5 m3/m2-h
! ====================================================================================================

AirflowNetwork:SimulationControl,
  AFN_Control,                    !- Name
  MultizoneWithoutDistribution,   !- AirflowNetwork Control
  SurfaceAverageCalculation;      !- Wind Pressure Coefficient Type

AirflowNetwork:MultiZone:Zone,
  TZ_BG3,                    !- Zone Name
  NoVent,          	     !- Ventilation Control Mode (so AFN doesn't override EMS)
  ,              	     !- Ventilation Control Zone Temperature Setpoint Schedule Name
  0.0,                       !- Minimum Venting Open Factor
  0.0,                       !- Indoor/Outdoor Temp Diff Lower Limit for Max Venting
  100.0,                     !- Indoor/Outdoor Temp Diff Upper Limit for Min Venting
  0.0,                       !- Indoor/Outdoor Enthalpy Diff Lower Limit (for Enthalpy mode)
  300000.0,                  !- Indoor/Outdoor Enthalpy Diff Upper Limit
  AlwaysOn,                  !- Venting Availability Schedule Name 
  ,                          !- Single Sided Wind Pressure Coefficient Algorithm 
  ,                          !- Façade Width
  ;                          !- Occupant Ventilation Control Name

! Total building ELA at 4 Pa: 0.025932 m2 (q_50 = 5 m3/m2-h) 
! Distribution (redistributed from ASHRAE Table 11):
!   Windows/Doors: 67% = 0.017288 m2 
!   Ceiling/Roof: 33% = 0.0092082 m2 
!   
! --------------------------------------------------------------------------------------------------
! 1. WINDOW/DOOR LEAKAGE (67% of total)

! Distributed by window/door perimeter
! Total window/door ELA = 0.017288 m2
! Total window/door perimeter (weighted) = 273.35 m
! ELA per m = 0.000063244 m2/m

! Perimeter for fixed windows are weighted by a factor of 1.0 to calculate ELA_i
! Perimeter for opaque doors are weighted by a factor of 1.5 to calculate ELA_i
! Perimeter for operable windows & glass doors are weighted by a factor of 2.0 to calculate ELA_i
! --------------------------------------------------------------------------------------------------

! 1.1 Fixed Windows & Exterior Doors

