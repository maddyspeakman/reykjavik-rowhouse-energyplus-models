! Bedroom windows (operable): W2, W23, W26, W29, W48
! Common-area windows (operable): W4, W6, W11, W15, W19, W32, W35, W38, W42, W44

!----------------------------------------------------
! Initialization
!----------------------------------------------------

EnergyManagementSystem:Program,
  Init_WindowState,
  SET EventTimer_min     = 0,
  SET EventActive        = 0,
  SET EventDemand        = 0,
  SET Open_Common        = 0,
  SET Open_Bedroom       = 0,
  SET Open_Day_Event     = 0,
  SET Open_Day_Summer    = 0,
  SET Open_Day_Winter    = 0,
  SET Open_Night         = 0,
  SET SummerMode         = 0;

EnergyManagementSystem:ProgramCallingManager,
  Init_WindowState_Manager,
  BeginNewEnvironment,
  Init_WindowState;

!----------------------------------------------------
! Main control
!----------------------------------------------------

EnergyManagementSystem:Program,
  WindowControl_Hybrid,

  ! Read sensors
  SET C_z   = TZ_BG3_CO2,
  SET T_z   = TZ_BG3_Temp,
  SET S_win = Occ_Avail,
  SET To    = T_out,
  SET Vw    = V_wind,

  ! Time
  SET hr    = Hour,
  SET mon   = Month,
  SET dtmin = 10.0,

  ! Control thresholds for non-summer daytime opening
  SET CO2_on      = 700.0,
  SET CO2_off     = 600.0,
  SET Temp_on     = T_setpoint + 0.7,
  SET Temp_off    = T_setpoint + 0.2,
  SET EventMinDur = 40.0,

  ! Weather reduction for non-summer daytime opening
  SET To_min = -20.0,
  SET To_max = 7.0,
  SET fT = (To - To_min) / (To_max - To_min),
  SET fT = @Max 0.0 fT,
  SET fT = @Min 1.0 fT,

  SET Vw_min = 6.0,
  SET Vw_max = 16.0,
  SET fW = 1.0 - (Vw - Vw_min) / (Vw_max - Vw_min),
  SET fW = @Max 0.0 fW,
  SET fW = @Min 1.0 fW,

  SET WeatherFactor = 0.50 + 0.35 * fT + 0.15 * fW,
  SET WeatherFactor = @Min 1.0 WeatherFactor,

  ! Summer / mild-weather mode
  SET SummerMode = 0,
  IF ((mon >= 5) && (mon <= 9) && (To >= 6.0)),
    SET SummerMode = 1,
  ENDIF,

  ! Summer wind limiter
  SET SummerWindFactor = 1.0,
  IF (Vw > 14.0),
    SET SummerWindFactor = 0.8,
  ENDIF,
  IF (Vw > 18.0),
    SET SummerWindFactor = 0.5,
  ENDIF,

  ! Daytime event demand outside summer
  SET EventDemand = 0,
  IF (C_z > CO2_on),
    SET EventDemand = 1,
  ENDIF,
  IF (T_z > Temp_on),
    SET EventDemand = 1,
  ENDIF,

  ! Keep non-summer daytime opening active for at least 40 minutes
  IF (EventActive > 0),

    SET EventTimer_min = EventTimer_min + dtmin,

    IF ((EventTimer_min >= EventMinDur) && (C_z < CO2_off) && (T_z < Temp_off)),
      SET EventActive = 0,
      SET EventTimer_min = 0,
    ENDIF,

  ELSE,

    IF ((EventDemand > 0) && (S_win > 0) && (SummerMode < 1)),
      SET EventActive = 1,
      SET EventTimer_min = 0,
    ENDIF,

  ENDIF,

  ! Common-area windows
  SET Open_Day_Event = 0,
  SET Open_Day_Event_base = 0.010,
  IF ((EventActive > 0) && (S_win > 0) && (SummerMode < 1)),
    SET Open_Day_Event = Open_Day_Event_base * WeatherFactor,
  ENDIF,

  SET Open_Day_Summer = 0,
  SET Open_Day_Summer_base = 0.015,
  IF (SummerMode > 0),
    SET Open_Day_Summer = Open_Day_Summer_base * SummerWindFactor,
  ENDIF,

  SET Open_Day_Winter = 0,
  SET Open_Day_Winter_base = 0.003,
  IF ((SummerMode < 1) && (S_win > 0)),
    SET Open_Day_Winter = Open_Day_Winter_base,
  ENDIF,

  ! Bedroom windows at night
  SET Open_Night = 0,
  SET Open_Night_Winter_base = 0.020,
  SET Open_Night_Summer_base = 0.040,

  IF ((hr >= 23) || (hr < 7)),
    IF (SummerMode > 0),
      SET Open_Night = Open_Night_Summer_base,
    ELSE,
      SET Open_Night = Open_Night_Winter_base,
    ENDIF,
  ENDIF,

  ! Assign by window group
  IF (SummerMode > 0),
    SET Open_Common = Open_Day_Summer,
  ELSE,
    SET Open_Common = @Max Open_Day_Event Open_Day_Winter,
  ENDIF,

  SET Open_Bedroom = Open_Night,

  ! Common-area windows
  SET AFN_W4_Opening  = Open_Common,
  SET AFN_W6_Opening  = Open_Common,
  SET AFN_W11_Opening = Open_Common,
  SET AFN_W15_Opening = Open_Common,
  SET AFN_W19_Opening = Open_Common,
  SET AFN_W32_Opening = Open_Common,
  SET AFN_W35_Opening = Open_Common,
  SET AFN_W38_Opening = Open_Common,
  SET AFN_W42_Opening = Open_Common,
  SET AFN_W44_Opening = Open_Common,

  ! Bedroom windows
  SET AFN_W2_Opening  = Open_Bedroom,
  SET AFN_W23_Opening = Open_Bedroom,
  SET AFN_W26_Opening = Open_Bedroom,
  SET AFN_W29_Opening = Open_Bedroom,
  SET AFN_W48_Opening = Open_Bedroom;

EnergyManagementSystem:ProgramCallingManager,
  WindowControlCalling,
  BeginTimestepBeforePredictor,
  WindowControl_Hybrid;


