!==========================================================================================
! Natural Ventilation Model: Window opening
!   CO2 and indoor temperature drive daytime opening outside summer
!   Summer opening is treated as a persistent background opening
!   Common-area windows and bedroom windows are handled separately
!==========================================================================================

! Build schedule for when occupants are available to open/close windows (home + awake)

Schedule:Day:Interval,
  Occ_Avail_Weekday,     !- Name
  Fractional,            !- Schedule Type Limits Name
  No,                    !- Interpolate to Timestep
  06:00, 0.0,            !- 00:00–06:00: no actions
  08:00, 1.0,            !- 06:00–08:00: actions allowed
  17:00, 0.0,            !- 08:00–17:00: no actions
  23:00, 1.0,            !- 17:00–23:00: actions allowed
  24:00, 0.0;            !- 23:00–24:00: no actions

Schedule:Day:Interval,
  Occ_Avail_Weekend,     !- Name
  Fractional,            !- Schedule Type Limits Name
  No,                    !- Interpolate to Timestep
  07:00, 0.0,            !- 00:00-07:00
  14:00, 1.0,            !- 07:00-14:00
  17:00, 0.0,            !- 14:00-17:00
  23:00, 1.0,            !- 17:00-23:00
  24:00, 0.0;            !- 23:00-24:00

Schedule:Week:Daily,
  Occ_Avail_Week,        !- Name
  Occ_Avail_Weekend,     ! Sunday
  Occ_Avail_Weekday,     ! Monday
  Occ_Avail_Weekday,     ! Tuesday
  Occ_Avail_Weekday,     ! Wednesday
  Occ_Avail_Weekday,     ! Thursday
  Occ_Avail_Weekday,     ! Friday
  Occ_Avail_Weekend,     ! Saturday
  Occ_Avail_Weekend,     ! Holiday
  Occ_Avail_Weekday,     ! SummerDesignDay
  Occ_Avail_Weekday,     ! WinterDesignDay
  Occ_Avail_Weekend,     ! CustomDay1
  Occ_Avail_Weekend;     ! CustomDay2

Schedule:Year,
  Occ_Avail_Sched,
  Fractional,
  Occ_Avail_Week,
  1, 1,
  12, 31;

