! 2. CEILING LEAKAGE (33% of total)

! Distributed by roof/ceiling area
! Total roof ELA = 0.0091402 m2
! Total roof area = 105.60 m2 
! ELA per m2 = 0.000086555 m2/m2 
! ---------------------------------------------

! East Roof (43.20 m2)
AirflowNetwork:MultiZone:Surface:EffectiveLeakageArea,
  ELA_Roof_E,               !- Leakage Area Name
  0.0037392,                !- Effective Leakage Area [m2]
  4.0,                      !- Reference Pressure Difference [Pa]
  0.75;                     !- Air Mass Flow Exponent

