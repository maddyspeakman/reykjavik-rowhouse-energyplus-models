! Roof overhang shading
!   East Wall 2: 1.1 m projection
!   West Wall 1: 1.3 m projection
!   West Wall 2: 0.6 m projection
!-----------------------------------------------------------------------------

Shading:Building:Detailed,
  Overhang_EastWall2,
  ,
  4,
  0.0,  0.0, 5.2,
  0.0, -1.1, 5.2,
  9.6, -1.1, 5.2,
  9.6,  0.0, 5.2;

Shading:Building:Detailed,
  Overhang_WestWall1,
  ,
  4,
  0.0, 11.0, 3.25,
  0.0, 12.3, 3.25,
  9.6, 12.3, 3.25,
  9.6, 11.0, 3.25;

Shading:Building:Detailed,
  Overhang_WestWall2,
  ,
  4,
  0.0, 11.0, 6.65,
  0.0, 11.6, 6.65,
  9.6, 11.6, 6.65,
  9.6, 11.0, 6.65;

!-------------------------------------------------
! HEATING & NO COOLING
!    Baseline: Indoor temp = 20ºC constantly
!-------------------------------------------------

ScheduleTypeLimits,
  Fractional,                             !- Name
  0,                                      !- Lower Limit Value
  1,                                      !- Upper Limit Value
  Continuous;                             !- Numeric Type

Schedule:Constant,
  AlwaysOn,            !- Name
  Fractional,          !- Schedule Type Limits Name
  1.0;                 !- Value

Schedule:Constant,
  AlwaysOff,           !- Name
  Fractional,          !- Schedule Type Limits Name
  0.0;                 !- Value

ScheduleTypeLimits,
  Temperature,         !- Name
  ,                    !- Lower Limit Value
  ,                    !- Upper Limit Value
  Continuous,          !- Numeric Type
  Temperature;         !- Unit Type

Schedule:Constant,
  HeatSP_20C,          !- Name
  Temperature,         !- Schedule Type Limits Name
  20.0;                !- Value

ThermostatSetpoint:SingleHeating,
  HTG_SP_TZ_BG2,           !- Name
