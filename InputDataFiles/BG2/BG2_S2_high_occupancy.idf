  Roof E,                   !- Surface Name
  ELA_Roof_E,               !- Leakage Component Name
  ,                         !- External Node Name
  ,                         !- Window/Door Opening Factor or Crack Factor
  NoVent,                   !- Ventilation Control Mode
  , , , , , , , , , ;       !- (leave remaining venting fields default)

! West Roof (62.40 m2)
AirflowNetwork:MultiZone:Surface:EffectiveLeakageArea,
  ELA_Roof_W,               !- Leakage Area Name
  0.0054010,                !- Effective Leakage Area [m2]
  4.0,                      !- Reference Pressure Difference [Pa]
  0.75;                     !- Air Mass Flow Exponent

AirflowNetwork:MultiZone:Surface,
  Roof W,                   !- Surface Name
