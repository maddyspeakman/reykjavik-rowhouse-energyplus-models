! 3.2 Operable Windows (use SimpleOpening to allow for both infiltration & ventilation)

! C = ELA_i * √(2 * rho_air * ∆P_ref) / (Perimeter_i * ∆P_ref^n)
! C = 0.00012086 kg/s-m (Air mass flow coefficient when opening is closed)

AirflowNetwork:MultiZone:Component:SimpleOpening,
  AFN_Operable_Infil,          !- Name
  0.00012086,                  !- Air Mass Flow Coefficient When Opening is Closed {kg/s-m}
  0.75,                        !- Air Mass Flow Exponent When Opening is Closed
  0.0001,                      !- Minimum Density Difference for Two-Way Flow {kg/m3}
  1.0;                         !- Discharge Coefficient

AirflowNetwork:MultiZone:Surface,
  Window 1 Operable,           !- Surface Name: Operable Window (South Patio)
  AFN_Operable_Infil,          !- Leakage Component Name
  ,                            !- External Node Name
  1.0E-10;                     !- Window/Door Opening Factor or Crack Factor (EMS will control)
  
AirflowNetwork:MultiZone:Surface,
  Window 3 Operable,           !- Surface Name: Operable Window (South Patio)
  AFN_Operable_Infil,          !- Leakage Component Name
  ,                            !- External Node Name
  1.0E-10;             	       !- Window/Door Opening Factor or Crack Factor (EMS will control)
  
AirflowNetwork:MultiZone:Surface,
